{
  "name": "quadra-backend",
  "version": "1.0.0",
  "description": "Backend do sistema de agendamento de quadra de futebol",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force && node prisma/seed.js",
    "studio": "prisma studio",
    "pretest": "cross-env DATABASE_URL=file:./test.db prisma migrate deploy",
    "test": "cross-env DATABASE_URL=file:./test.db node --test --test-concurrency=1 tests/*.test.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0"
  }
}
